    IF  !:DEF: __VADISKADAPTERREGS_INC
__VADISKADAPTERREGS_INC EQU 1

;;/------------------------------------------------------------------------------

VADISKADAPTER_OFFSET_VID            EQU 0x0000
VADISKADAPTER_OFFSET_PID            EQU 0x0004
VADISKADAPTER_OFFSET_VERSION        EQU 0x0008

VADISKADAPTER_OFFSET_CTRLSTAT       EQU 0x0010
VADISKADAPTER_OFFSET_INTSTAT        EQU 0x0014
VADISKADAPTER_OFFSET_INTMASK        EQU 0x0018
VADISKADAPTER_OFFSET_INTPEND        EQU 0x001C

VADISKADAPTER_OFFSET_INTSETMASK     EQU 0x0020
VADISKADAPTER_OFFSET_INTCLRMASK     EQU 0x0024

VADISKADAPTER_OFFSET_DISKTOTALSECT  EQU 0x0030
VADISKADAPTER_OFFSET_SESSIONID      EQU 0x0034
VADISKADAPTER_OFFSET_WINDOWCMD      EQU 0x0038
VADISKADAPTER_OFFSET_WINDOWARG      EQU 0x003C

VADISKADAPTER_OFFSET_WIN0_BUFOFFSET EQU 0x0040
VADISKADAPTER_OFFSET_WIN0_STARTSECT EQU 0x0044
VADISKADAPTER_OFFSET_WIN0_SECTRUN   EQU 0x0048

VADISKADAPTER_OFFSET_WIN1_BUFOFFSET EQU 0x0050
VADISKADAPTER_OFFSET_WIN1_STARTSECT EQU 0x0054
VADISKADAPTER_OFFSET_WIN1_SECTRUN   EQU 0x0058

VADISKADAPTER_OFFSET_WIN2_BUFOFFSET EQU 0x0060
VADISKADAPTER_OFFSET_WIN2_STARTSECT EQU 0x0064
VADISKADAPTER_OFFSET_WIN2_SECTRUN   EQU 0x0068

VADISKADAPTER_OFFSET_WIN3_BUFOFFSET EQU 0x0070
VADISKADAPTER_OFFSET_WIN3_STARTSECT EQU 0x0074
VADISKADAPTER_OFFSET_WIN3_SECTRUN   EQU 0x0078

VADISKADAPTER_OFFSET_MEDIAGUID_0    EQU 0x0080
VADISKADAPTER_OFFSET_MEDIAGUID_1    EQU 0x0084
VADISKADAPTER_OFFSET_MEDIAGUID_2    EQU 0x0088
VADISKADAPTER_OFFSET_MEDIAGUID_3    EQU 0x008C

;;/---------------------------------------------------------------------

VIRTARM_DISKADAPTER_VID             EQU 0x0000045E
VIRTARM_DISKADAPTER_PID             EQU 0x00000606

VIRTARM_DISKADAPTER_CTRLSTAT_ENABLE_TOGGLE  EQU 0x80000000
VIRTARM_DISKADAPTER_CTRLSTAT_MEDIA_PRESENCE EQU 0x00000001
VIRTARM_DISKADAPTER_CTRLSTAT_MEDIA_READONLY EQU 0x00000002

VIRTARM_DISKADAPTER_INTR_PRESENCE_CHANGE    EQU 0x00000001
VIRTARM_DISKADAPTER_INTR_ALL                EQU 0x00000001

;;/---------------------------------------------------------------------

VIRTARM_DISKADAPTER_SRAM_OFFSET_SECTORBUFFER    EQU 0
VIRTARM_DISKADAPTER_SECTOR_BYTES                EQU 512
VIRTARM_DISKADAPTER_MAX_NUM_SECTORS             EQU ((VIRTARM_PHYSSIZE_ADAPTER_SRAM - VIRTARM_DISKADAPTER_SRAM_OFFSET_SECTORBUFFER) / VIRTARM_DISKADAPTER_SECTOR_BYTES)

;;/---------------------------------------------------------------------

VIRTARM_DISKADAPTER_WINDOWCMD_IXMASK            EQU 0x0000000F
VIRTARM_DISKADAPTER_WINDOWCMD_CMDMASK           EQU 0x00000030

VIRTARM_DISKADAPTER_WINDOWCMD_FRAME             EQU 0x00000010
VIRTARM_DISKADAPTER_WINDOWCMD_FLUSH_WRITE       EQU 0x00000020

VIRTARM_DISKADAPTER_IOERR_NONE                  EQU 0
VIRTARM_DISKADAPTER_IOERR_OUTOFRANGE            EQU 0x807B0001
VIRTARM_DISKADAPTER_IOERR_BADCOMMAND            EQU 0x807B0002
VIRTARM_DISKADAPTER_IOERR_READONLY              EQU 0x807B0003

