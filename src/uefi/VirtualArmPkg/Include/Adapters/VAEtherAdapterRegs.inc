    IF  !:DEF: __VAETHERADAPTERREGS_INC
__VAETHERADAPTERREGS_INC EQU 1

;;/------------------------------------------------------------------------------

    IF  !:DEF: ETHERNET_MTU
ETHERNET_MTU    EQU 1518
    ENDIF
    
;;/------------------------------------------------------------------------------

VAETHERADAPTER_OFFSET_VID               EQU 0x0000
VAETHERADAPTER_OFFSET_PID               EQU 0x0004
VAETHERADAPTER_OFFSET_VERSION           EQU 0x0008

VAETHERADAPTER_OFFSET_CONTROLSTATUS     EQU 0x0010
VAETHERADAPTER_OFFSET_INTSTATUS         EQU 0x0014
VAETHERADAPTER_OFFSET_INTMASK           EQU 0x0018
VAETHERADAPTER_OFFSET_INTPEND           EQU 0x001C

VAETHERADAPTER_OFFSET_INTSETMASK        EQU 0x0020
VAETHERADAPTER_OFFSET_INTCLRMASK        EQU 0x0024

VAETHERADAPTER_OFFSET_FILTERCONTROL_16  EQU 0x0028
VAETHERADAPTER_OFFSET_MAC01_16          EQU 0x002A
VAETHERADAPTER_OFFSET_MAC23_16          EQU 0x002C
VAETHERADAPTER_OFFSET_MAC45_16          EQU 0x002E

VAETHERADAPTER_OFFSET_IOCOMMANDSTATUS   EQU 0x0030
VAETHERADAPTER_OFFSET_IOVAR1            EQU 0x0034
VAETHERADAPTER_OFFSET_IOVAR2            EQU 0x0038

;;/---------------------------------------------------------------------

VIRTARM_ETHERADAPTER_VID                EQU 0x0000045E
VIRTARM_ETHERADAPTER_PID                EQU 0x00000505

;;/---------------------------------------------------------------------

;; SRAM is used entirely for frame i/o 
VIRTARM_ETHERADAPTER_SRAM_OFFSET_FRAMESBUFFER   EQU 0
VIRTARM_ETHERADAPTER_FRAME_MAX_BYTES            EQU ETHERNET_MTU
VIRTARM_ETHERADAPTER_MAX_NUM_FRAMES             EQU ((VIRTARM_PHYSSIZE_ADAPTER_SRAM - VIRTARM_ETHERADAPTER_SRAM_OFFSET_FRAMESBUFFER) / VIRTARM_ETHERADAPTER_FRAME_MAX_BYTES)

;; read - whether the interface is enabled and can send/recv 
;; write - toggle to opposite state 
VIRTARM_ETHERADAPTER_CTRLSTAT_ENABLE            EQU 0x00000001

;; read - whether a cable is connected or not 
;; write - nothing 
VIRTARM_ETHERADAPTER_CTRLSTAT_CABLESENSE        EQU 0x80000000

VIRTARM_ETHERADAPTER_INTR_RECV_AVAIL            EQU 0x00000001 
VIRTARM_ETHERADAPTER_INTR_XMIT_EMPTY            EQU 0x00000002
VIRTARM_ETHERADAPTER_INTR_ALL                   EQU 0x00000003

VIRTARM_ETHERADAPTER_FILTER_ALLOW_NONE          EQU 0x00000000
VIRTARM_ETHERADAPTER_FILTER_ALLOW_DIRECTED      EQU 0x00000001
VIRTARM_ETHERADAPTER_FILTER_ALLOW_MULTICAST     EQU 0x00000002
VIRTARM_ETHERADAPTER_FILTER_ALLOW_ALL_MULTICAST EQU 0x00000004
VIRTARM_ETHERADAPTER_FILTER_ALLOW_BROADCAST     EQU 0x00000008
VIRTARM_ETHERADAPTER_FILTER_ALLOW_PROMISCUOUS   EQU 0x00000020
VIRTARM_ETHERADAPTER_FILTER_MASK                EQU 0x0000002F

;; IO commands for frames 
VIRTARM_ETHERADAPTER_IOCMD_GETXMITBUF           EQU 1   
VIRTARM_ETHERADAPTER_IOCMD_DOXMIT               EQU 2   
VIRTARM_ETHERADAPTER_IOCMD_GETRECVBUF           EQU 3   
VIRTARM_ETHERADAPTER_IOCMD_RELEASE              EQU 4   
VIRTARM_ETHERADAPTER_IOCMD_QUERY_BUFSIZE        EQU 5
VIRTARM_ETHERADAPTER_IOCMD_HOLDRECVBUF          EQU 6

;; IO errors - read the command register after a write to get these 
VIRTARM_ETHERADAPTER_IOERR_NONE                 EQU 0
VIRTARM_ETHERADAPTER_IOERR_BADCOMMAND           EQU 0x807A0001
VIRTARM_ETHERADAPTER_IOERR_NODATA               EQU 0x807A0002
VIRTARM_ETHERADAPTER_IOERR_BADRELEASE           EQU 0x807A0003
VIRTARM_ETHERADAPTER_IOERR_FRAMETOOBIG          EQU 0x807A0004
VIRTARM_ETHERADAPTER_IOERR_FRAMETOOSMALL        EQU 0x807A0005
VIRTARM_ETHERADAPTER_IOERR_BADFRAMEPTR          EQU 0x807A0006
VIRTARM_ETHERADAPTER_IOERR_NOFREEFRAMES         EQU 0x807A0007
VIRTARM_ETHERADAPTER_IOERR_NOTTXFRAME           EQU 0x807A0008
VIRTARM_ETHERADAPTER_IOERR_TXFAILED             EQU 0x807A0009

;;/------------------------------------------------------------------------------

    ENDIF    ; __VAETHERADAPTERREGS_INC

    END 


